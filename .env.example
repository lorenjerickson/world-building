LLM_PROVIDER=node-llama-cpp
LLM_MAX_TOKENS=2048
# Shared secret required on rule-set API requests from a trusted BFF/gateway.
RULE_API_INTERNAL_TOKEN=replace-with-a-short-lived-service-credential

# used when LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_PORTRAIT_IMAGE_MODEL=gpt-image-2
OPENAI_TOKEN_IMAGE_MODEL=gpt-image-1.5

# Used when LLM_PROVIDER=node-llama-cpp. Docker mounts ./models at /models.
LLAMA_MODEL_PATH=/models/Meta-Llama-3.1-8B-Instruct-Q8_0.gguf
LLAMA_CONTEXT_SIZE=8192
LLAMA_GPU_LAYERS=auto

CMS_POSTGRES_PASSWORD=replace-with-a-database-password
CMS_PAYLOAD_SECRET=replace-with-at-least-32-random-characters
CMS_INTERNAL_TOKEN=replace-with-a-short-lived-service-credential
CMS_S3_ACCESS_KEY_ID=replace-with-storage-access-key
CMS_S3_SECRET_ACCESS_KEY=replace-with-storage-secret-key
CMS_S3_BUCKET=worldcms-media
CMS_S3_REGION=us-east-1

AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://replace-with-your-tenant.us.auth0.com
AUTH0_CLIENT_ID=replace-with-your-client-id
AUTH0_CLIENT_SECRET=replace-with-your-client-secret

# 64 character random string to encrypt the session cookie
#
# We're generating a secret for your convenience, but for production,
# generate your own secret using `openssl rand -hex 32`
AUTH0_SECRET=replace-with-64-character-session-secret
