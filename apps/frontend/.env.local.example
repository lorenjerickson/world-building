# Server-side calls from Next.js to NestJS. NEXT_PUBLIC_API_URL is retained
# for browser-facing URLs; secrets must never use the NEXT_PUBLIC_ prefix.
BACKEND_URL='http://127.0.0.1:8000'
NEXT_PUBLIC_API_URL='http://127.0.0.1:8000'
RULE_API_INTERNAL_TOKEN='replace-with-the-same-value-used-by-apps-backend'
