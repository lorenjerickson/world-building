{
  "name": "@world-building/backend",
  "version": "1.0.0",
  "description": "AI RPG World Builder API in NestJS",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test:rules": "pnpm build && node --test test/rules-api.test.js",
    "migration:run": "pnpm build && typeorm migration:run -d dist/database/data-source.js",
    "migration:show": "pnpm build && typeorm migration:show -d dist/database/data-source.js",
    "migration:revert": "pnpm build && typeorm migration:revert -d dist/database/data-source.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "level": "^8.0.1",
    "levelgraph": "^4.0.0",
    "node-llama-cpp": "^3.19.0",
    "openai": "^4.52.0",
    "pg": "^8.11.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "node-llama-cpp",
      "fsevents",
      "classic-level",
      "@nestjs/core"
    ]
  }
}
