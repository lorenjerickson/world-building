# Local NestJS dependencies
DATABASE_URL=postgresql://worldbuilder:password123@127.0.0.1:5432/worlddb
CMS_BASE_URL=http://127.0.0.1:3100
CMS_INTERNAL_TOKEN=replace-with-the-same-value-used-by-apps-cms
RULE_API_INTERNAL_TOKEN=replace-with-the-same-value-used-by-apps-frontend

# Language model provider: openai or node-llama-cpp
LLM_PROVIDER=openai
LLM_MAX_TOKENS=2048
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_PORTRAIT_IMAGE_MODEL=gpt-image-2
OPENAI_TOKEN_IMAGE_MODEL=gpt-image-1.5

# Used only when LLM_PROVIDER=node-llama-cpp.
LLAMA_MODEL_PATH=../../models/model.gguf
LLAMA_CONTEXT_SIZE=8192
LLAMA_GPU_LAYERS=auto

# Optional Apple Silicon acceleration for node-llama-cpp.
# GGML_METAL=1
