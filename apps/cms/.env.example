CMS_POSTGRES_PASSWORD=replace-with-a-database-password
CMS_DATABASE_HOST=127.0.0.1
CMS_DATABASE_PORT=5433
CMS_DATABASE_NAME=worldcms
CMS_DATABASE_USER=worldcms
PAYLOAD_SECRET=replace-with-at-least-32-random-characters
CMS_INTERNAL_TOKEN=replace-with-a-short-lived-service-credential
CMS_BASE_URL=http://127.0.0.1:3100
# Development-only Payload admin login. This is ignored when NODE_ENV=production.
CMS_ENABLE_LOCAL_ADMIN=false
# Set these only in the ignored apps/cms/.env before running `pnpm admin:local`.
CMS_LOCAL_ADMIN_EMAIL=
CMS_LOCAL_ADMIN_PASSWORD=
S3_ACCESS_KEY_ID=replace-with-storage-access-key
S3_SECRET_ACCESS_KEY=replace-with-storage-secret-key
S3_BUCKET=worldcms-media
S3_ENDPOINT=http://127.0.0.1:9000
S3_FORCE_PATH_STYLE=true
S3_REGION=us-east-1
